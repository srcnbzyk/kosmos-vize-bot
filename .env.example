TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# TC kimlik no (veya sistemin beklediği nationalityNumber)
NATIONALITY_NUMBER=xxxxxxxxxxx

# /api/Dealers listesinden: 1=Istanbul, 5=Izmir, 1014=Ankara, 1017=Edirne, ...
DEALER_ID=1

# INDIVIDUAL | FAMILY
APPLICATION_TYPE=INDIVIDUAL

# STANDARD | VIP | EEA_AB_SPOUSE | BT
APPOINTMENT_TYPE=STANDARD

# Opsiyonel: site login sonrasi Bearer token (localStorage). Yoksa API 401 donebilir.
AUTH_TOKEN=

# Opsiyonel: frontend'in gonderdigi reCAPTCHA token. Yoksa istek reddedilebilir.
RECAPTCHA_TOKEN=

# Kac gun ileriye bakilsin / kac saniye beklesin
DAYS_AHEAD=30
CHECK_INTERVAL_SECONDS=300
